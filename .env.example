# =============================================================================
# .env.example — Template des variables d'environnement
#
# IMPORTANT : Ne jamais commiter le fichier .env reel dans git !
#             Seul ce fichier .env.example est versionne.
#
# Usage :
#   cp .env.example .env      puis editer .env avec les vraies valeurs
#
# Principe :
#   Ces variables ont PRIORITE sur les valeurs des fichiers YAML.
#   Les secrets (tokens, mots de passe) vont ICI, jamais dans le YAML.
#   En CI/CD, ces variables sont injectees par le systeme de secrets.
# =============================================================================

# Environnement : dev | staging | prod
# Selectionne configs/<ENV>.yaml
ENV=dev

# --- Spark -------------------------------------------------------------------
SPARK_MASTER=local[*]
SPARK_APP_NAME=spark-project
SPARK_LOG_LEVEL=WARN

# --- Stockage ----------------------------------------------------------------
# dev  : chemin local  (data/lake)
# prod : chemin cloud  (s3a://bucket/datalake)
DATA_LAKE_PATH=data/lake
CHECKPOINT_PATH=data/checkpoints

# --- AWS (si applicable) - NE PAS mettre les vraies valeurs ici ! -----------
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=eu-west-1

# --- Databricks (si applicable) ---------------------------------------------
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_token_here

# --- Alertes ----------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
ALERT_EMAIL=data-team@company.com

# --- Logs -------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=text
